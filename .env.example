# ==============================================================================
# HireMind AI - Environment Variables Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ==============================================================================
# Database Configuration
# ==============================================================================
DB_NAME=hiremind_db
DB_USER=hiremind_user
DB_PASSWORD=secure_password_change_me
DB_PORT=5432

# ==============================================================================
# PgAdmin Configuration
# ==============================================================================
PGADMIN_EMAIL=admin@hiremind.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ==============================================================================
# Backend (Java Spring Boot) Configuration
# ==============================================================================
BACKEND_PORT=8080
SPRING_PROFILE=prod

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_EXPIRATION=86400000

# API Configuration
SERVER_SERVLET_CONTEXT_PATH=/api

# Logging
LOG_LEVEL=INFO

# ==============================================================================
# AI/LLM API Keys
# ==============================================================================
# OpenAI Configuration (for GPT-4, GPT-3.5)
OPENAI_API_KEY=sk_test_your_openai_api_key_here

# Anthropic Configuration (for Claude)
ANTHROPIC_API_KEY=sk_ant_your_anthropic_api_key_here

# ==============================================================================
# Frontend (React) Configuration
# ==============================================================================
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_ENV=production

# ==============================================================================
# Security & Production Settings
# ==============================================================================
# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,docx,doc,txt

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ==============================================================================
# Application Features
# ==============================================================================
# Feature Flags
ENABLE_BATCH_PROCESSING=true
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOGGING=true

# PDF Processing
PDF_PARSER_TIMEOUT=30
PDF_MAX_PAGES=100

# Resume Analysis
MIN_SIMILARITY_THRESHOLD=0.6
MAX_SUGGESTIONS_COUNT=10

# ==============================================================================
# Email Configuration (Optional)
# ==============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@hiremind.local

# ==============================================================================
# Monitoring & Logging
# ==============================================================================
# Log Configuration
LOG_FORMAT=json
LOG_OUTPUT_PATH=./logs

# Application Insights (Optional)
APP_INSIGHTS_CONNECTION_STRING=

# ==============================================================================
# External Services
# ==============================================================================
# Sentry Error Tracking (Optional)
SENTRY_DSN=

# Datadog Integration (Optional)
DATADOG_API_KEY=
